# Django
DJANGO_SECRET_KEY=change-me-in-production-use-50-random-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=kampanyekit.id,www.kampanyekit.id
DJANGO_SETTINGS_MODULE=config.settings.production

# Database
DATABASE_URL=postgres://kampanyekit:strongpassword@db:5432/kampanyekit

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Google Cloud Storage (optional — leave blank to use local media)
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
# Mount service account JSON at /app/credentials/gcs-key.json

# Email (Gmail example — use App Password, not real password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Meta Ads (optional)
META_APP_ID=
META_APP_SECRET=

# TikTok Ads (optional)
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# Anthropic (Phase 3)
ANTHROPIC_API_KEY=

# Sentry (production error tracking)
SENTRY_DSN=
