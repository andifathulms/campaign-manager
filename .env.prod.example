# ─── Postgres ────────────────────────────────────────────────────────
POSTGRES_DB=kampanyekit
POSTGRES_USER=kampanyekit
POSTGRES_PASSWORD=CHANGE_ME

# ─── App ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://kampanyekit:CHANGE_ME@db:5432/kampanyekit
REDIS_URL=redis://redis:6379/0
DJANGO_SECRET_KEY=CHANGE_ME_50_RANDOM_CHARS
DJANGO_ALLOWED_HOSTS=kampanyekit.id,www.kampanyekit.id

# ─── Frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://kampanyekit.id/api/v1
NEXT_PUBLIC_APP_URL=https://kampanyekit.id
NEXTAUTH_URL=https://kampanyekit.id
NEXTAUTH_SECRET=CHANGE_ME_32_RANDOM_CHARS

# ─── GitHub Container Registry ───────────────────────────────────────
GITHUB_REPOSITORY=your-org/campaign-manager
IMAGE_TAG=latest

# ─── GCS (optional) ──────────────────────────────────────────────────
GCS_BUCKET_NAME=
GCS_PROJECT_ID=

# ─── Email ───────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ─── CAPTCHA (public forms: supporter join, aspirasi) ────────────────
# Leave CAPTCHA_SECRET blank to disable verification (rate limiting still
# applies). Provider: 'turnstile' (Cloudflare) or 'recaptcha' (Google).
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET=

# ─── Secrets-at-rest encryption (ad/WhatsApp tokens) ─────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ─── WhatsApp (OTP + notifications) ──────────────────────────────────
# WHATSAPP_BACKEND: 'console' (dev) or 'fonnte' (prod)
WHATSAPP_BACKEND=console
WHATSAPP_API_KEY=

# ─── Meta Ads ────────────────────────────────────────────────────────
# Leave APP_ID/SECRET blank (or set META_SANDBOX=True) to use placeholder
# data — the connect/sync/dashboard/control flow works without live API.
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=https://kampanyekit.id/dashboard/ads/callback
META_SANDBOX=False
