# Public API URL (browser-facing — use your actual domain in production)
NEXT_PUBLIC_API_URL=https://kampanyekit.id/api/v1
NEXT_PUBLIC_APP_URL=https://kampanyekit.id

# NextAuth
NEXTAUTH_URL=https://kampanyekit.id
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Internal backend URL (server-side only — Docker service name)
NEXTAUTH_BACKEND_URL=http://backend:8000/api/v1

# Meta OAuth (for ads connection — optional)
NEXT_PUBLIC_META_APP_ID=

# TikTok OAuth (optional)
NEXT_PUBLIC_TIKTOK_APP_ID=
